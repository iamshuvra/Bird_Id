# Python virtual environment (we create this locally, don't commit it)
venv/
env/
.env

# Python bytecode cache (auto-generated, not needed in git)
__pycache__/
*.pyc
*.pyo

# Model weight files (too large for git, download separately)
*.pt
*.pth
*.weights
*.onnx

# Raw video clips and extracted frames (large files, store separately)
data/raw_clips/
data/frames/

# YOLO label files (these get generated by our scripts)
data/yolo_labels/

# Jupyter notebook checkpoints
.ipynb_checkpoints/

# OS junk files
.DS_Store
Thumbs.db

# VSCode workspace settings (personal preference, don't force on others)
.vscode/
